# Personal AI Employee - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ===================
# Core Settings
# ===================
DRY_RUN=true                          # Set to false only in production
VAULT_PATH=./AI_Employee_Vault        # Path to Obsidian vault

# ===================
# Claude Code
# ===================
ANTHROPIC_API_KEY=                    # Your Anthropic API key (if not using router)
CLAUDE_MODEL=claude-sonnet-4-20250514 # Default model

# ===================
# Gmail Watcher
# ===================
GMAIL_CREDENTIALS_PATH=./config/gmail_credentials.json
GMAIL_TOKEN_PATH=./config/gmail_token.json
GMAIL_CHECK_INTERVAL=120              # Seconds between checks
GMAIL_QUERY=is:unread is:important    # Gmail search query

# ===================
# WhatsApp Watcher
# ===================
WHATSAPP_SESSION_PATH=./config/whatsapp_session
WHATSAPP_CHECK_INTERVAL=30            # Seconds between checks
WHATSAPP_HEADLESS=false               # Set true after initial login

# ===================
# File System Watcher
# ===================
FILESYSTEM_WATCH_PATH=./AI_Employee_Vault/Drop
FILESYSTEM_CHECK_INTERVAL=5           # Seconds between checks

# ===================
# Rate Limits (per hour)
# ===================
RATE_LIMIT_EMAILS=10
RATE_LIMIT_PAYMENTS=3
RATE_LIMIT_SOCIAL_POSTS=5

# ===================
# Approval Thresholds
# ===================
AUTO_APPROVE_THRESHOLD=50             # Max $ for auto-approval to known vendors
REQUIRE_APPROVAL_THRESHOLD=100        # Always require approval above this

# ===================
# Logging
# ===================
LOG_LEVEL=INFO                        # DEBUG, INFO, WARNING, ERROR
LOG_RETENTION_DAYS=90                 # Days to keep logs

# ===================
# Gold Tier: Odoo Integration
# ===================
ODOO_URL=https://mycompany.odoo.com   # Odoo instance URL
ODOO_DATABASE=mycompany               # Database name
ODOO_USERNAME=                        # Odoo username
ODOO_API_KEY=                         # API key (32+ characters)
ODOO_SYNC_INTERVAL=300                # Seconds between syncs

# ===================
# Gold Tier: Facebook/Instagram
# ===================
FACEBOOK_PAGE_ID=                     # Facebook Page ID
FACEBOOK_ACCESS_TOKEN=                # Page access token (long-lived)
INSTAGRAM_BUSINESS_ID=                # Instagram Business Account ID
INSTAGRAM_ACCESS_TOKEN=               # Instagram access token

# ===================
# Gold Tier: Twitter/X
# ===================
TWITTER_API_KEY=                      # Twitter API Key
TWITTER_API_SECRET=                   # Twitter API Secret
TWITTER_ACCESS_TOKEN=                 # OAuth 2.0 Access Token
TWITTER_ACCESS_SECRET=                # OAuth 2.0 Access Secret
TWITTER_BEARER_TOKEN=                 # Bearer Token for v2 API

# ===================
# Gold Tier: CEO Briefing
# ===================
BRIEFING_SCHEDULE="0 23 * * 0"        # Cron: Sunday 11 PM
BRIEFING_TIMEOUT=600                  # Max generation time (seconds)
BRIEFING_OUTPUT_PATH=./AI_Employee_Vault/Briefings
