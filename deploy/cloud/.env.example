# AI Employee Platinum Tier - Cloud Agent Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# ============================================
# Agent Configuration
# ============================================
AGENT_ID=cloud
WORK_ZONE=cloud
DRY_RUN=false

# ============================================
# Claude API
# ============================================
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# Vault Configuration
# ============================================
VAULT_PATH=/home/ubuntu/AI_Employee_Vault

# ============================================
# Git Sync
# ============================================
GIT_SYNC_INTERVAL=30
GIT_AUTO_PUSH=true
GIT_REMOTE=origin
GIT_BRANCH=main

# ============================================
# Gmail (Read-Only Token)
# ============================================
GMAIL_CREDENTIALS_PATH=/home/ubuntu/.config/ai-employee/gmail_credentials.json
GMAIL_TOKEN_PATH=/home/ubuntu/.config/ai-employee/gmail_token.json
GMAIL_CHECK_INTERVAL=120

# ============================================
# Odoo (Read-Only Operations)
# ============================================
ODOO_URL=http://localhost:8069
ODOO_DATABASE=mycompany
ODOO_USERNAME=cloud-agent
ODOO_API_KEY=your-read-only-api-key

# ============================================
# Docker / PostgreSQL (for Odoo)
# ============================================
POSTGRES_PASSWORD=generate-a-strong-password-here

# ============================================
# Health Monitoring
# ============================================
CHECK_INTERVAL=60
ALERT_EMAIL=your-email@example.com

# ============================================
# DO NOT INCLUDE ON CLOUD:
# - WhatsApp credentials
# - Payment tokens
# - Social media posting tokens
# - Banking credentials
# ============================================
